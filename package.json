{
  "name": "game-artist-task-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "server": "cd server && node src/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install:all": "cd server && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
